# Copie para .env (git-ignored) e preencha a anon key do projeto Supabase.
# URL e anon key são públicas por design (o front roda no browser); a segurança
# vem da RLS. Pegue a anon key em: Supabase Dashboard > Project Settings > API.
VITE_SUPABASE_URL=https://lgqexlhbpxfkzrsvbknz.supabase.co
VITE_SUPABASE_ANON_KEY=
# Usada em links de retorno (Stripe) e no e-mail de convite. Em produção, a URL do app.
VITE_APP_URL=http://localhost:5173
# Opcional — só para billing real: Stripe Dashboard > Product > Price ID (price_...).
# Em produção, configure nas Environment Variables do projeto na Vercel.
# VITE_STRIPE_PRICE_ID=
