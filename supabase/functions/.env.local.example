# Copie para supabase/functions/.env.local (git-ignored) para `supabase functions serve`.
# Em produção, use: supabase secrets set STRIPE_SECRET_KEY=... STRIPE_WEBHOOK_SECRET=... APP_URL=...
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY são injetados automaticamente
# no runtime das Edge Functions; defina-os aqui apenas para o serve local.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
APP_URL=http://localhost:5173
